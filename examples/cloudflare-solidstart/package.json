{
  "name": "solidstart-example",
  "type": "module",
  "scripts": {
    "dev": "vite dev --port 3000",
    "build": "vite build",
    "preview": "vite preview",
    "setup:solid-start": "git submodule update --init solid-start-fork && cd solid-start-fork && pnpm install && pnpm build",
    "deploy": "bun ../../alchemy-effect/bin/alchemy-effect.js deploy",
    "destroy": "bun ../../alchemy-effect/bin/alchemy-effect.js destroy"
  },
  "dependencies": {
    "@solidjs/meta": "^0.29.4",
    "@solidjs/router": "^0.15.3",
    "@solidjs/start": "./solid-start-fork/packages/start",
    "solid-js": "^1.9.9",
    "start-oauth": "^1.3.0",
    "unstorage": "1.17.1",
    "vite": "^7.0.0",
    "@solidjs/vite-plugin-nitro-2": "./solid-start-fork/packages/start-nitro-v2-vite-plugin",
    "alchemy-effect": "workspace:*",
    "effect": "catalog:"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.1.13",
    "tailwindcss": "^4.1.13"
  },
  "engines": {
    "node": ">=22"
  }
}